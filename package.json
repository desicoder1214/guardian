{
  "name": "guardian",
  "version": "0.5.0",
  "private": true,
  "description": "Guardian security kernel foundation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src tests package.json tsconfig*.json .eslintrc.json jest.config.js .prettierrc",
    "format:check": "prettier --check src tests package.json tsconfig*.json .eslintrc.json jest.config.js .prettierrc",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --runInBand",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.11.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "27.2.0",
    "jest": "29.5.0",
    "prettier": "3.0.0",
    "ts-jest": "29.1.0",
    "typescript": "5.5.4"
  }
}
