# Guardian runtime startup configuration
# Copy this file to .env and replace placeholder values.

# Required: startup mode. Allowed values: production, validation, testing, certification
GUARDIAN_RUNTIME_MODE=production

# Required: deterministic runtime identifier for logs, traces, and startup coordination
GUARDIAN_RUNTIME_ID=guardian-runtime-local

# Required: Discord guild/server id Guardian protects
GUARDIAN_GUILD_ID=YOUR_GUILD_ID

# Required: Discord bot token with permissions for your target guild
DISCORD_BOT_TOKEN=REPLACE_WITH_DISCORD_BOT_TOKEN

# Required: comma-separated Discord gateway intents used by runtime configuration
DISCORD_GATEWAY_INTENTS=GUILDS,GUILD_MEMBERS,GUILD_WEBHOOKS,GUILD_INTEGRATIONS,GUILD_EMOJIS_AND_STICKERS

# Optional: Discord presence status (default: online)
DISCORD_PRESENCE_STATUS=online

# Optional: Discord API base URL (default: https://discord.com)
DISCORD_API_BASE_URL=https://discord.com

# Optional: execution safety mode for in-memory execution guards
NODE_ENV=development

# Optional: comma-separated authorization and trust inventories consumed by canonical runtime
GUARDIAN_TRUSTED_INVITER_IDS=
GUARDIAN_AUTHORIZED_BOT_IDS=
GUARDIAN_TRUSTED_BOT_IDS=
GUARDIAN_AUTHORIZED_WEBHOOK_IDS=
GUARDIAN_AUTHORIZED_INTEGRATION_IDS=
GUARDIAN_AUTHORIZED_CHANNEL_IDS=
GUARDIAN_AUTHORIZED_OVERWRITE_IDS=
GUARDIAN_TRUSTED_CHANNEL_ADMIN_IDS=
GUARDIAN_AUTHORIZED_ROLE_IDS=
GUARDIAN_TRUSTED_ROLE_ADMIN_IDS=
GUARDIAN_AUTHORIZED_MEMBER_IDS=
GUARDIAN_TRUSTED_MEMBER_ADMIN_IDS=
GUARDIAN_AUTHORIZED_EMOJI_IDS=
GUARDIAN_AUTHORIZED_STICKER_IDS=
